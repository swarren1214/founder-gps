# apps/web deployment environment template
# Use this for Vercel Project Environment Variables.

# Public web origin (used by auth and callbacks)
NEXT_PUBLIC_APP_URL=https://your-app-name.vercel.app

# --- External provider keys (server-side) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ROADMAP_MODEL=gpt-4o-mini
OPENAI_ONBOARDING_MODEL=gpt-4o-mini
AI_MODEL=gpt-4o-mini

# Optional alternative provider key (if used by your intelligence service)
GEMINI_API_KEY=

# OpenRouteService routing
OPENROUTESERVICE_API_KEY=
# Backward compatible alias (either works)
ORS_API_KEY=

# --- Service URLs consumed by Next.js API routes ---
# Use private server-side vars first.
RESOURCE_SERVICE_URL=
ROUTING_SERVICE_URL=
INTELLIGENCE_SERVICE_URL=
RECOMMENDATION_SERVICE_URL=
AUTH_SERVICE_URL=

# Optional backward-compatible public aliases
NEXT_PUBLIC_RESOURCE_SERVICE_URL=
NEXT_PUBLIC_ROUTING_SERVICE_URL=
NEXT_PUBLIC_INTELLIGENCE_SERVICE_URL=
NEXT_PUBLIC_RECOMMENDATION_SERVICE_URL=
NEXT_PUBLIC_AUTH_SERVICE_URL=

# --- Supabase (optional: if using Supabase DB/Auth directly in web app) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
