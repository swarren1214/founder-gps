# ============================================================
# Founder GPS Environment Example
#
# Notes:
# - Copy this file to `.env` for local development.
# - Keep secrets server-side only. Do not expose provider keys.
# - `NEXT_PUBLIC_*` variables are intentionally exposed to the browser.
# ============================================================

# -----------------------------
# Database
# -----------------------------
DATABASE_URL=postgresql://founder:founderpass@localhost:55432/founder_gps

# -----------------------------
# Service Ports (Local Runtime)
# -----------------------------
RESOURCE_SERVICE_PORT=4001
ROUTING_SERVICE_PORT=4002
INTELLIGENCE_SERVICE_PORT=4003
RECOMMENDATION_SERVICE_PORT=4004
AUTH_SERVICE_PORT=4005

# -----------------------------
# Authentication Session Configuration
# -----------------------------
AUTH_COOKIE_NAME=fg_session
AUTH_SESSION_TTL_DAYS=14
AUTH_AVATAR_STORAGE_DIR=.data/avatars
AUTH_AVATAR_PUBLIC_BASE_URL=http://localhost:4005/profile/avatar

# -----------------------------
# Internal Service URLs (Server-to-Server)
# Used by backend services and orchestrators.
# -----------------------------
RESOURCE_SERVICE_URL=http://localhost:4001
ROUTING_SERVICE_URL=http://localhost:4002
INTELLIGENCE_SERVICE_URL=http://localhost:4003
RECOMMENDATION_SERVICE_URL=http://localhost:4004
AUTH_SERVICE_URL=http://localhost:4005

# -----------------------------
# AI Provider Configuration
# `heuristic` works without external API keys.
# -----------------------------
AI_PROVIDER=heuristic
AI_MODEL=heuristic-v1
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_ROADMAP_MODEL=mistralai/mistral-nemotron

# Provider API keys (leave empty unless provider is enabled)
OPENAI_API_KEY=
GEMINI_API_KEY=
LOGO_DEV_API_KEY=
BRANDFETCH_API_KEY=
OPENROUTESERVICE_API_KEY=
ORS_API_KEY=

# -----------------------------
# OSRM Routing Configuration
# -----------------------------
OSRM_HOST_PORT=5001
OSRM_BASE_URL=http://localhost:5001
OSRM_REQUEST_TIMEOUT_MS=5000
OSRM_MAX_RETRIES=2

# Local OSRM data artifact configuration
OSRM_DATA_PATH=/Users/stephenwarren/Developer/opswift/monorepo/osrm-data
OSRM_DATA_BASENAME=utah-latest.osrm

# -----------------------------
# Web Client Service URLs (Browser-Exposed)
# Must use NEXT_PUBLIC_ prefix for Next.js client-side access.
# -----------------------------
NEXT_PUBLIC_RESOURCE_SERVICE_URL=http://localhost:4001
NEXT_PUBLIC_ROUTING_SERVICE_URL=http://localhost:4002
NEXT_PUBLIC_INTELLIGENCE_SERVICE_URL=http://localhost:4003
NEXT_PUBLIC_RECOMMENDATION_SERVICE_URL=http://localhost:4004
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:4005

# -----------------------------
# Supabase (optional for web direct integration)
# -----------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
